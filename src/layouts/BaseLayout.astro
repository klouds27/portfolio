---
import Nav from '../components/Nav.astro';
import '../styles/global.css';

interface Props {
  title?: string;
}

const { title = 'deb adalwolf' } = Astro.props;
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" href="/favicon.ico" />
    <title>{title}</title>
  </head>
  <body>
    <Nav />
    <main>
      <slot />
    </main>
    <footer class="site-footer">
      <span class="site-footer__email">
        <a href="mailto:adolfogonzpe@gmail.com">adolfogonzpe@gmail.com</a>
      </span>
      <span class="site-footer__github">
        <a href="https://github.com/klouds27" target="_blank" rel="noopener">github.com/klouds27 ↗</a>
      </span>
    </footer>
  </body>
</html>

<style>
  .site-footer {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 2rem 4rem;
    border-top: 1px solid var(--border);
    font-family: var(--font-mono);
    font-size: 12px;
    color: var(--fg-ghost);
  }

  .site-footer a {
    color: var(--fg-ghost);
    transition: color 0.15s ease;
  }

  .site-footer a:hover {
    color: var(--fg-dim);
  }

  @media (max-width: 640px) {
    .site-footer {
      flex-direction: column;
      gap: 0.5rem;
      padding: 1.5rem 1.5rem;
      text-align: center;
    }
  }
</style>
