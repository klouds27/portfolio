---
import Nav from '../components/Nav.astro';
import '../styles/global.css';

interface Props {
  title?: string;
  description?: string;
}

const {
  title = 'Adolfo González del Corral',
  description = 'Backend & mobile developer. APIs y aplicaciones móviles con Python, Java, Flutter y Docker. Contribuidor en Spring Security e iCalendar.',
} = Astro.props;

const canonical = new URL(Astro.url.pathname, Astro.site ?? 'https://klouds27.dev');
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="canonical" href={canonical} />

    <title>{title}</title>
    <meta name="description" content={description} />

    <meta property="og:type"        content="website" />
    <meta property="og:url"         content={canonical} />
    <meta property="og:title"       content={title} />
    <meta property="og:description" content={description} />

    <meta name="twitter:card"        content="summary" />
    <meta name="twitter:title"       content={title} />
    <meta name="twitter:description" content={description} />

    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  </head>
  <body>
    <Nav />
    <main>
      <slot />
    </main>
    <footer class="site-footer" id="contacto">
      <span class="site-footer__email">
        <a href="mailto:adolfogonzpe@gmail.com">adolfogonzpe@gmail.com</a>
      </span>
      <div class="site-footer__links">
        <a href="https://github.com/klouds27" target="_blank" rel="noopener">github ↗</a>
        <a href="https://www.linkedin.com/in/adolfo-gonz%C3%A1lez-del-corral/" target="_blank" rel="noopener">linkedin ↗</a>
      </div>
    </footer>
  </body>
</html>

<style>
  .site-footer {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 2rem 4rem;
    border-top: 1px solid var(--border);
    font-family: var(--font-mono);
    font-size: 12px;
    color: var(--fg-ghost);
  }

  .site-footer__links {
    display: flex;
    gap: 1.5rem;
  }

  .site-footer a {
    color: var(--fg-ghost);
    transition: color 0.15s ease;
  }

  .site-footer a:hover {
    color: var(--fg-dim);
  }

  @media (max-width: 640px) {
    .site-footer {
      flex-direction: column;
      gap: 0.75rem;
      padding: 1.5rem;
      text-align: center;
    }

    .site-footer__links {
      gap: 1rem;
    }
  }
</style>
