---

<section class="hero" id="inicio">
  <div class="hero-content">
    <p class="hero-eyebrow">// backend & mobile developer</p>
    <h1 class="hero-name">Adolfo González del Corral<span class="hero-cursor" aria-hidden="true"></span></h1>
    <p class="hero-desc">APIs y aplicaciones móviles. Python, Java, Flutter, Docker. Contribuidor en Spring Security e iCalendar.</p>

    <div class="hero-ctas">
      <a href="#proyectos" class="cta-primary">ver proyectos</a>
      <a href="https://github.com/klouds27" target="_blank" rel="noopener" class="cta-secondary">github ↗</a>
      <a href="https://www.linkedin.com/in/adolfo-gonz%C3%A1lez-del-corral/" target="_blank" rel="noopener" class="cta-secondary">linkedin ↗</a>
    </div>
  </div>

  <div class="hero-dots" aria-hidden="true"></div>
</section>

<style>
  .hero {
    padding: 7rem 4rem 5rem;
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 4rem;
    align-items: center;
    max-width: 1200px;
  }

  .hero-content > * {
    opacity: 0;
    transform: translateY(12px);
    animation: fade-up 0.5s ease forwards;
  }

  .hero-eyebrow {
    font-family: var(--font-mono);
    font-size: 13px;
    color: var(--accent-label);
    margin-bottom: 1.25rem;
    animation-delay: 0.05s;
  }

  .hero-name {
    font-family: var(--font-mono);
    font-size: 40px;
    font-weight: 700;
    color: var(--fg);
    line-height: 1.1;
    margin-bottom: 1.5rem;
    animation-delay: 0.15s;
  }

  .hero-cursor {
    display: inline-block;
    width: 3px;
    height: 0.85em;
    background-color: var(--accent-label);
    margin-left: 4px;
    vertical-align: middle;
    animation:
      fade-up 0.5s ease 0.15s forwards,
      blink 1s step-end 0.65s infinite;
    opacity: 0;
  }

  .hero-desc {
    font-size: 15px;
    color: var(--fg-dim);
    line-height: 1.65;
    margin-bottom: 2.5rem;
    animation-delay: 0.25s;
  }

  .hero-ctas {
    display: flex;
    gap: 1rem;
    align-items: center;
    animation-delay: 0.35s;
  }

  .cta-primary {
    font-family: var(--font-mono);
    font-size: 13px;
    padding: 0.6rem 1.25rem;
    background-color: var(--accent);
    color: var(--accent-text);
    border-radius: var(--radius-btn);
    transition: background-color 0.15s ease;
  }

  .cta-primary:hover {
    background-color: #003d88;
  }

  .cta-secondary {
    font-family: var(--font-mono);
    font-size: 13px;
    color: var(--fg-dim);
    transition: color 0.15s ease;
  }

  .cta-secondary:hover {
    color: var(--fg);
  }

  /* dot grid */

  .hero-dots {
    position: relative;
    width: 100%;
    height: 320px;
    -webkit-mask-image: radial-gradient(ellipse 80% 80% at 60% 50%, black 30%, transparent 100%);
    mask-image: radial-gradient(ellipse 80% 80% at 60% 50%, black 30%, transparent 100%);
  }

  .hero-dots,
  .hero-dots::before,
  .hero-dots::after {
    background-image: radial-gradient(circle, rgba(120, 163, 199, 0.3) 1px, transparent 1px);
    background-size: 22px 22px;
    animation: dot-pulse 4s ease-in-out infinite;
  }

  .hero-dots {
    background-position: 0 0;
    animation-delay: 0s;
  }

  .hero-dots::before,
  .hero-dots::after {
    content: '';
    position: absolute;
    inset: 0;
  }

  .hero-dots::before {
    background-position: 11px 11px;
    animation-delay: -1.3s;
  }

  .hero-dots::after {
    background-position: 0 11px;
    animation-delay: -2.6s;
  }

  @keyframes dot-pulse {
    0%, 100% { opacity: 0.2; }
    50%       { opacity: 0.9; }
  }

  @keyframes fade-up {
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  @keyframes blink {
    50% { opacity: 0; }
  }

  @media (max-width: 900px) {
    .hero {
      grid-template-columns: 1fr;
      gap: 0;
    }

    .hero-dots {
      display: none;
    }
  }

  @media (max-width: 640px) {
    .hero {
      padding: 4rem 1.5rem 3rem;
    }

    .hero-name {
      font-size: 32px;
    }
  }
</style>
